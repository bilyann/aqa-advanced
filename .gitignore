# Залежності (найголовніше, що не можна пушити)
node_modules/
/jspm_packages/

# Логи (автоматично створюються при помилках)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Системні файли macOS (приховані файли провідника Finder)
.DS_Store
.AppleDouble
.LSOverride

# Налаштування IDE (папка з локальними конфігами VS Code)
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Майбутні звіти та скріншоти тестів (для Cypress / Playwright)
/cypress/screenshots/
/cypress/videos/
/playwright-report/
/test-results/

# Змінні оточення (паролі, токени, секрети — ніколи не пушити!)
.env
.env.local